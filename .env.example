# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7

# Backend security (generate strong random strings)
BACKEND_API_KEY=change_me_backend_api_key
ADMIN_API_KEY=change_me_admin_api_key

# Database
POSTGRES_PASSWORD=psychologue
DATABASE_URL=postgresql+asyncpg://psychologue:psychologue@postgres:5432/psychologue

# Redis
REDIS_URL=redis://redis:6379/0

# Bot -> Backend
BACKEND_URL=http://api:8000

# Quotas
FREE_DAILY_QUOTA=30
PREMIUM_DAILY_QUOTA=500
MAX_MESSAGE_LENGTH=2000
MAX_HISTORY_MESSAGES=20
RATE_LIMIT_SECONDS=2

# Logging
LOG_LEVEL=INFO
