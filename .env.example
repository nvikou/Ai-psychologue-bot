# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_MODE=false
WEBHOOK_URL=
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_PORT=8080

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7

# Backend security (generate strong random strings)
BACKEND_API_KEY=change_me_backend_api_key
ADMIN_API_KEY=change_me_admin_api_key
ADMIN_JWT_SECRET=change_me_admin_jwt_secret
ENCRYPTION_KEY=change_me_long_random_encryption_key

# Database
POSTGRES_PASSWORD=psychologue
DATABASE_URL=postgresql+asyncpg://psychologue:psychologue@postgres:5432/psychologue

# Redis
REDIS_URL=redis://redis:6379/0

# Bot -> Backend
BACKEND_URL=http://api:8000
TELEGRAM_BOT_USERNAME=ai_psychologueBot
PUBLIC_BASE_URL=http://localhost:8000

# Quotas / limits
FREE_DAILY_QUOTA=30
PREMIUM_DAILY_QUOTA=500
MAX_MESSAGE_LENGTH=2000
MAX_HISTORY_MESSAGES=20
RATE_LIMIT_SECONDS=2
IP_RATE_LIMIT_PER_MINUTE=60

# GDPR / i18n
MESSAGE_RETENTION_DAYS=90
DEFAULT_LANGUAGE=en
CORS_ORIGINS=*

# Optional monitoring / escalation
SENTRY_DSN=
CRISIS_WEBHOOK_URL=

# Logging
LOG_LEVEL=INFO
